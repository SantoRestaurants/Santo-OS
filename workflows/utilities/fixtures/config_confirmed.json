{
  "workflow_key": "utility_receipts_matching",
  "providers": {
    "cfe": {
      "name": "CFE (Comisión Federal de Electricidad)",
      "service_number_pattern": "^\\d{12}$",
      "payment_method": "direct_debit"
    },
    "agua": {
      "name": "Agua / SIAPA",
      "service_number_pattern": "^\\d{8}$",
      "payment_method": "manual_transfer"
    },
    "gas": {
      "name": "Gas Natural",
      "service_number_pattern": "^\\d{10}$",
      "payment_method": "credit_card"
    }
  },
  "matching_rules": {
    "subject_keywords": ["recibo", "CFE", "agua", "gas"],
    "attachment_types": ["application/pdf", "image/jpeg", "image/png"]
  },
  "reviewer_map": {
    "default": "admin_ops"
  },
  "drive_folder_map": {
    "cfe": "drive-folder-cfe",
    "agua": "drive-folder-agua",
    "gas": "drive-folder-gas"
  }
}
