# SantoOS P0 environment example.
# Copy to .env.local or a deployment-specific secret store. Never commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[CONFIRM]
SUPABASE_SERVICE_ROLE_KEY=[CONFIRM]

# Dashboard
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AgentMail (santoos@agentmail.to)
AGENTMAIL_API_KEY=[CONFIRM]
AGENTMAIL_INBOX_ID=santoos@agentmail.to

# Google Drive connector
# Production: use OAuth refresh-token credentials for the dedicated Santo Google identity.
GOOGLE_DRIVE_CLIENT_ID=[CONFIRM]
GOOGLE_DRIVE_CLIENT_SECRET=[CONFIRM]
GOOGLE_DRIVE_REFRESH_TOKEN=[CONFIRM]
# Optional local-only fallback for short demos. Do not use for production.
GOOGLE_DRIVE_ACCESS_TOKEN=[CONFIRM]
GOOGLE_DRIVE_CONNECTOR_CONFIG=[CONFIRM]

# Workflow defaults
SANTO_DEFAULT_PHASE=P0
SANTO_DEFAULT_DOMAIN=admin_hr_payroll_accounting_fiscal

# Runtime
LOG_LEVEL=INFO

# AI (Claude)
ANTHROPIC_API_KEY=[CONFIRM]
CORTE_VISION_MODEL=[CONFIRM]

# Corte Santo runtime
CORTE_SANTO_CONFIG_PATH=workflows/corte_santo/fixtures/config_confirmed.json
CORTE_SANTO_INGRESOS_FILE_ID=[CONFIRM]
CORTE_SANTO_FORECAST_FILE_ID=[CONFIRM]
# Optional local-only workbook paths for controlled tests.
CORTE_SANTO_INGRESOS_PATH=[CONFIRM]
CORTE_SANTO_FORECAST_PATH=[CONFIRM]
