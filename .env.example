# SantoOS P0 environment example.
# Copy to .env.local or a deployment-specific secret store. Never commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[CONFIRM].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[CONFIRM]
# Legacy anon keys still work in Supabase, but new publishable keys are preferred.
NEXT_PUBLIC_SUPABASE_ANON_KEY=[CONFIRM]
SUPABASE_SERVICE_ROLE_KEY=[CONFIRM]
SUPABASE_DB_URL=postgresql://[CONFIRM]

# Dashboard
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Agent Mail
AGENT_MAIL_INBOX_ADDRESS=[CONFIRM]
AGENT_MAIL_ROUTING_MODE=[CONFIRM]

# Workflow defaults
SANTO_DEFAULT_PHASE=P0
SANTO_DEFAULT_DOMAIN=admin_hr_payroll_accounting_fiscal
SANTO_DEFAULT_UNIT_ID=[CONFIRM]
SANTO_DEFAULT_REVIEW_OWNER=[CONFIRM]

# Runtime
LOG_LEVEL=INFO
